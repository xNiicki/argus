# Copy to .env on each agent host.
# Central Loki push endpoint (the homelab/hetzner central stack):
LOKI_URL=http://argus.lan:3100
# Hostname label applied to this agent's logs (defaults to the OS hostname):
AGENT_HOSTNAME=pve1
# Textfile collector output dir (for cron scripts):
TEXTFILE_DIR=/var/lib/node_exporter/textfile
