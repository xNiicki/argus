# ============================================================================
# Argus — environment. Copy to `.env` and fill in. NEVER commit `.env`.
# ============================================================================

# --- Identity of THIS Argus instance --------------------------------------
# Each side (homelab + Hetzner) runs its own stack with a distinct SITE.
# Used in alert text and for peer cross-watch.
ARGUS_SITE=homelab                 # homelab | hetzner
ARGUS_EXTERNAL_URL=http://argus.lan:8088   # how YOU reach this narrator (for log/ack links)
ARGUS_TAG=latest                   # narrator image tag pulled from GHCR (latest | v1.2.3 | <sha>)

# --- ntfy ------------------------------------------------------------------
NTFY_SERVER=https://ntfy.xniicki.de
NTFY_TOPIC=argus
NTFY_TOKEN=                          # ntfy access token (tk_...), optional if topic is open
# Bypass-DND tag config for Emergency tier (iOS: requires per-topic setting too)

# --- Prometheus (for the narrator's context enrichment) -------------------
PROMETHEUS_URL=http://prometheus:9090

# --- Proxmox / prometheus-pve-exporter ------------------------------------
# Create a dedicated PVE API token: user e.g. argus@pve, role PVEAuditor.
# Configure in pve-exporter/pve.yml (copy from pve.yml.example).
PVE_TARGET=192.168.1.10              # PVE node address probed via pve-exporter

# --- Peer cross-watch ------------------------------------------------------
# URL of the OTHER side's narrator. Each side pings the other; if the peer is
# unreachable AND we can't reach it, we raise an alarm locally — so an outage
# cannot silence its own alarm.
PEER_NARRATOR_URL=https://hetzner.example.net:8088
PEER_SITE=hetzner

# --- Narrator tuning -------------------------------------------------------
NARRATOR_LOG_LEVEL=INFO
WATCHDOG_DEADLINE_SECONDS=180        # if no Watchdog heartbeat within this, self-alarm

# --- Phase 4: LLM root-cause hints via OpenRouter (optional) ---------------
# Leave OPENROUTER_API_KEY empty to disable. The LLM only ADDS a one-line
# "likely cause" guess to alerts; it never gates or delays a notification.
OPENROUTER_API_KEY=                  # sk-or-... ; empty => LLM hints off
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet   # any OpenRouter model slug
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_ENABLED=true                     # set false to disable even when a key is present
