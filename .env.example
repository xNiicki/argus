# ============================================================================
# Argus — copy to `.env`, fill in, then `docker compose up -d`.
# This is the ONLY file you edit. NEVER commit your `.env`.
# ============================================================================

# --- Identity --------------------------------------------------------------
ARGUS_SITE=argus                       # short name for this deployment (appears in alerts)
ARGUS_EXTERNAL_URL=http://localhost:8088   # how YOU reach the narrator (ack/log links)
ARGUS_TAG=latest                       # image tag to run (latest | v1.2.3)

# --- Alerting (ntfy) -------------------------------------------------------
NTFY_SERVER=https://ntfy.sh            # your ntfy server (or the public ntfy.sh)
NTFY_TOPIC=argus                       # pick a private, hard-to-guess topic
NTFY_TOKEN=                            # ntfy token (tk_...); needed for protected topics

# --- WHAT to monitor -------------------------------------------------------
# Comma-separated lists. Each entry: `host:port`, or `name=host:port` for a
# friendly label, and append `!insecure` to skip TLS verify (self-signed certs).
# Leave any blank to disable that check. Examples are illustrative — replace them.
#
#   ARGUS_NODE_TARGETS=web1=10.0.0.5:9100,db1=10.0.0.6:9100      # node_exporter hosts
#   ARGUS_CADVISOR_TARGETS=web1=10.0.0.5:8080                    # cAdvisor (containers)
#   ARGUS_HTTP_TARGETS=site=https://example.com                  # HTTP up + cert
#   ARGUS_TCP_TARGETS=ssh=10.0.0.5:22                            # raw TCP port checks
#   ARGUS_ICMP_TARGETS=gw=10.0.0.1,wan=1.1.1.1                   # ping/reachability
#   ARGUS_SSL_TARGETS=pve=https://10.0.0.10:8006!insecure        # cert-expiry tracking
#   ARGUS_DNS_TARGETS=10.0.0.1                                   # resolver checks
ARGUS_NODE_TARGETS=
ARGUS_CADVISOR_TARGETS=
ARGUS_HTTP_TARGETS=
ARGUS_TCP_TARGETS=
ARGUS_ICMP_TARGETS=
ARGUS_SSL_TARGETS=
ARGUS_DNS_TARGETS=

# --- Proxmox (optional) ----------------------------------------------------
# Create a read-only API token: pveum user token add argus@pve monitoring --privsep 0
# Leave ARGUS_PVE_TARGET blank to disable Proxmox monitoring entirely.
ARGUS_PVE_TARGET=                      # Proxmox node address, e.g. 10.0.0.10
PVE_USER=argus@pve
PVE_TOKEN_NAME=monitoring
PVE_TOKEN_VALUE=                       # the API token secret (UUID); KEEP SECRET

# --- Peer cross-watch (optional, multi-site) -------------------------------
# Run a second Argus elsewhere and point each at the other so one site can raise
# the alarm if the other (incl. its narrator) goes dark. Leave blank for single-site.
PEER_NARRATOR_URL=
PEER_SITE=

# --- LLM root-cause hints (optional) ---------------------------------------
# Empty key => disabled. Only ADDS a one-line "likely cause" to alerts.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_ENABLED=true

# --- Misc ------------------------------------------------------------------
NARRATOR_LOG_LEVEL=INFO
WATCHDOG_DEADLINE_SECONDS=180
# PROMETHEUS_PORT=9090                 # host port overrides (uncomment to change)
# NARRATOR_PORT=8088
